<ui:FluentWindow x:Class="Richie.UI.Views.Assets.AssetDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        mc:Ignorable="d"
        Title="Asset details"
        Height="720" Width="700"
        WindowStartupLocation="CenterOwner"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        WindowCornerPreference="Round">
    <ui:FluentWindow.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        
        <!-- Overrides to replace every red accent with Primary: #2563EB -->
        <Color x:Key="SystemAccentColor">#2563EB</Color>
        <SolidColorBrush x:Key="SystemAccentColorBrush" Color="#2563EB" />
        <Color x:Key="SystemAccentColorLight1">#3B82F6</Color>
        <SolidColorBrush x:Key="SystemAccentColorLight1Brush" Color="#3B82F6" />
        <Color x:Key="SystemAccentColorLight2">#60A5FA</Color>
        <SolidColorBrush x:Key="SystemAccentColorLight2Brush" Color="#60A5FA" />
        <Color x:Key="SystemAccentColorLight3">#93C5FD</Color>
        <SolidColorBrush x:Key="SystemAccentColorLight3Brush" Color="#93C5FD" />
        
        <Color x:Key="SystemAccentColorDark1">#1D4ED8</Color>
        <SolidColorBrush x:Key="SystemAccentColorDark1Brush" Color="#1D4ED8" />
        <Color x:Key="SystemAccentColorDark2">#1E40AF</Color>
        <SolidColorBrush x:Key="SystemAccentColorDark2Brush" Color="#1E40AF" />
        <Color x:Key="SystemAccentColorDark3">#1E3A8A</Color>
        <SolidColorBrush x:Key="SystemAccentColorDark3Brush" Color="#1E3A8A" />

        <!-- Custom button style to guarantee blue fill state by default, hover, and press -->
        <Style x:Key="BluePrimaryButtonStyle" TargetType="ui:Button">
            <Setter Property="Background" Value="#2563EB" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#1D4ED8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ui:Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="4" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1D4ED8" />
                                <Setter TargetName="border" Property="BorderBrush" Value="#1E40AF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1E3A8A" />
                                <Setter TargetName="border" Property="BorderBrush" Value="#1E3A8A" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#E2E8F0" />
                                <Setter TargetName="border" Property="BorderBrush" Value="#E2E8F0" />
                                <Setter Property="Foreground" Value="#94A3B8" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </ui:FluentWindow.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Asset details" />

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24,16,24,16">
            <StackPanel>
                <!-- Header Section -->
                <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" 
                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" 
                        BorderThickness="1" 
                        CornerRadius="8" 
                        Padding="20" 
                        Margin="0,0,0,20">
                    <StackPanel>
                        <ui:TextBlock FontTypography="TitleLarge" FontSize="26" FontWeight="Bold" Text="{Binding Name}" />
                        <ui:TextBlock Appearance="Secondary" FontSize="16" Margin="0,4,0,0" Text="{Binding TypeName}" />
                        <ui:TextBlock Appearance="Tertiary" FontSize="14" Margin="0,2,0,0" Text="{Binding CategoryName}" />
                    </StackPanel>
                </Border>

                <!-- Images Section -->
                <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" 
                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" 
                        BorderThickness="1" 
                        CornerRadius="8" 
                        Padding="20" 
                        Margin="0,0,0,20"
                        Visibility="{Binding HasImages, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <ui:TextBlock FontSize="18" FontWeight="SemiBold" Text="Images &amp; Documents" Margin="0,0,0,12" />
                        <ItemsControl ItemsSource="{Binding Images}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource ControlFillColorDefaultBrush}" 
                                            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" 
                                            BorderThickness="1" 
                                            CornerRadius="6" 
                                            Margin="0,0,12,12"
                                            Padding="8">
                                        <StackPanel>
                                            <Image Source="{Binding Thumbnail}" 
                                                   Width="200" 
                                                   Height="150" 
                                                   Stretch="UniformToFill" 
                                                   RenderOptions.BitmapScalingMode="HighQuality" />
                                            <ui:TextBlock Text="{Binding FileName}" 
                                                          FontSize="12" 
                                                          TextTrimming="CharacterEllipsis" 
                                                          Margin="0,8,0,0" 
                                                          TextAlignment="Center" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Details Section -->
                <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" 
                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" 
                        BorderThickness="1" 
                        CornerRadius="8" 
                        Padding="20" 
                        Margin="0,0,0,20">
                    <StackPanel>
                        <ui:TextBlock FontSize="18" FontWeight="SemiBold" Text="Asset Details" Margin="0,0,0,16" />
                        <ItemsControl ItemsSource="{Binding Rows}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="180" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <ui:TextBlock Grid.Column="0" 
                                                      Appearance="Secondary" 
                                                      FontSize="14" 
                                                      FontWeight="Medium"
                                                      Text="{Binding Label}" 
                                                      VerticalAlignment="Top" />
                                        <ui:TextBlock Grid.Column="1" 
                                                      FontSize="15" 
                                                      TextWrapping="Wrap" 
                                                      Text="{Binding Value}" 
                                                      VerticalAlignment="Top" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Profit/Loss Section -->
                        <Border Background="{DynamicResource ControlFillColorSecondaryBrush}" 
                                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" 
                                BorderThickness="1" 
                                CornerRadius="6" 
                                Padding="16" 
                                Margin="0,16,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <ui:TextBlock Grid.Column="0" 
                                              Appearance="Secondary" 
                                              FontSize="14" 
                                              FontWeight="Medium"
                                              Text="Profit / Loss" 
                                              VerticalAlignment="Center" />
                                <ui:TextBlock Grid.Column="1" 
                                              FontSize="18" 
                                              FontWeight="SemiBold"
                                              Foreground="{Binding ProfitLossBrush}"
                                              Text="{Binding ProfitLossText}" 
                                              VerticalAlignment="Center" />
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Exclusion Checkbox -->
                <CheckBox Margin="0,0,0,20"
                          Content="Exclude from portfolio valuation"
                          FontSize="14"
                          IsChecked="{Binding IsExcluded}"
                          Visibility="{Binding IsJewellery, Converter={StaticResource BoolToVis}}" />
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="24,8,24,16">
            <ui:Button Content="Edit" Margin="0,0,8,0" Command="{Binding EditCommand}" />
            <ui:Button Content="Close" Style="{StaticResource BluePrimaryButtonStyle}" Command="{Binding CloseCommand}" />
        </StackPanel>
    </Grid>
</ui:FluentWindow>
