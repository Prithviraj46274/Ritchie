<ui:FluentWindow x:Class="Richie.UI.Views.Assets.AddEditGoalWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        mc:Ignorable="d"
        Title="Goal"
        Height="620" Width="460"
        WindowStartupLocation="CenterOwner"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        WindowCornerPreference="Round">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="{Binding Title}" />

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24,8,24,8">
            <StackPanel>
                <ui:TextBox PlaceholderText="Goal name (e.g. Retirement)" Margin="0,0,0,10"
                            Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />
                <ui:TextBox PlaceholderText="Target amount" Margin="0,0,0,10"
                            Text="{Binding TargetAmountText, UpdateSourceTrigger=PropertyChanged}" />

                <ui:TextBlock Text="Target date" Margin="0,0,0,4" />
                <DatePicker SelectedDate="{Binding TargetDate}" Margin="0,0,0,10" />

                <ui:TextBlock Text="Priority" Margin="0,0,0,4" />
                <ComboBox ItemsSource="{Binding Priorities}" DisplayMemberPath="Text" SelectedValuePath="Value"
                          SelectedValue="{Binding Priority}" Margin="0,0,0,16" />

                <ui:TextBlock FontTypography="BodyStrong" Text="Linked assets" Margin="0,0,0,4" />
                <ui:TextBlock Appearance="Secondary" Margin="0,0,0,8"
                              Text="Tag the assets that contribute to this goal." />
                <ItemsControl ItemsSource="{Binding AssetPicks}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <CheckBox Content="{Binding Name}" IsChecked="{Binding IsLinked, Mode=TwoWay}" Margin="0,2" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <ui:TextBlock Foreground="#C42B1C" TextWrapping="Wrap" Margin="0,8,0,0" Text="{Binding Error}" />
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="24,8,24,16">
            <ui:Button Content="Cancel" Margin="0,0,8,0" Command="{Binding CancelCommand}" />
            <ui:Button Content="Save" Appearance="Primary" Command="{Binding SaveCommand}" />
        </StackPanel>
    </Grid>
</ui:FluentWindow>
