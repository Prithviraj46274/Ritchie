<ui:FluentWindow x:Class="Richie.UI.Views.Expenses.BillsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        mc:Ignorable="d"
        Title="Bills &amp; receipts"
        Height="600" Width="820"
        WindowStartupLocation="CenterOwner"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        WindowCornerPreference="Round">
    <ui:FluentWindow.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </ui:FluentWindow.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Bills &amp; receipts" />

        <Grid Grid.Row="1" Margin="24,8,24,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <DockPanel Grid.Column="0">
                <ui:TextBlock DockPanel.Dock="Top" FontTypography="BodyStrong" Text="{Binding Heading}" Margin="0,0,0,8" />
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                    <ui:Button Content="Attach bill" Appearance="Primary" Click="OnAttach" Margin="0,0,8,0" />
                    <ui:Button Content="Delete" Click="OnDelete" />
                </StackPanel>
                <ui:TextBlock DockPanel.Dock="Bottom" Appearance="Secondary" FontTypography="Caption"
                              TextWrapping="Wrap" Margin="0,8,0,0"
                              Text="Previewable: PNG, JPG, JPEG, BMP, GIF, WEBP. Other files (e.g. PDF): use Download." />
                <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,8,0,0">
                    <ui:Button Content="Previous" Click="OnPrevious" Margin="0,0,8,0" IsEnabled="{Binding HasMultiple}" />
                    <ui:Button Content="Next" Click="OnNext" IsEnabled="{Binding HasMultiple}" />
                </StackPanel>
                <ui:TextBlock DockPanel.Dock="Bottom" Appearance="Secondary" Margin="0,8,0,0"
                              Text="No bills attached yet."
                              Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisibilityConverter}}" />
                <ListBox ItemsSource="{Binding Items}" SelectedItem="{Binding SelectedDocument}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="0,2">
                                <ui:TextBlock Text="{Binding FileName}" />
                                <ui:TextBlock Appearance="Secondary" FontSize="11">
                                    <Run Text="{Binding Kind, Mode=OneWay}" />
                                    <Run Text="{Binding SizeBytes, Mode=OneWay, StringFormat=' · {0:N0} bytes'}" />
                                </ui:TextBlock>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>

            <Border Grid.Column="2" BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="1" CornerRadius="6">
                <Grid Margin="12">
                    <ui:TextBlock Appearance="Secondary" TextWrapping="Wrap"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"
                                  Text="{Binding PreviewMessage}" />
                    <Image Source="{Binding PreviewImage}" Stretch="Uniform" />
                    <ui:Button Content="Download" HorizontalAlignment="Right" VerticalAlignment="Bottom" Click="OnDownload" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</ui:FluentWindow>
