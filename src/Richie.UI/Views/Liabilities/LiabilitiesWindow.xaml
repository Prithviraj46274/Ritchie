<ui:FluentWindow x:Class="Richie.UI.Views.Liabilities.LiabilitiesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        Title="Liabilities &amp; Loans"
        Height="760" Width="980"
        WindowStartupLocation="CenterOwner"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        WindowCornerPreference="Round">
    <ui:FluentWindow.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </ui:FluentWindow.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Liabilities &amp; Loans" />

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24,8,24,16">
            <StackPanel>

                <!-- Header -->
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ui:TextBlock Grid.Column="0" FontTypography="TitleLarge"
                                  Text="Loans &amp; Liabilities"
                                  Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                  VerticalAlignment="Center" />
                    <ui:Button Grid.Column="1" Content="Add loan"
                               Appearance="Primary" Click="OnAddLoan" />
                </Grid>

                <!-- Summary cards row 1 -->
                <Grid Margin="0,0,0,12" Height="100">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <ui:Card Grid.Column="0" Padding="12">
                        <StackPanel VerticalAlignment="Center">
                            <ui:TextBlock Appearance="Secondary" FontTypography="Caption"
                                          HorizontalAlignment="Center" Text="Total Outstanding" Margin="0,0,0,6" />
                            <ui:TextBlock FontTypography="Subtitle" HorizontalAlignment="Center"
                                          Text="{Binding TotalOutstanding, StringFormat='&#x20B9;{0:N0}'}" />
                        </StackPanel>
                    </ui:Card>
                    <ui:Card Grid.Column="2" Padding="12">
                        <StackPanel VerticalAlignment="Center">
                            <ui:TextBlock Appearance="Secondary" FontTypography="Caption"
                                          HorizontalAlignment="Center" Text="Monthly EMI" Margin="0,0,0,6" />
                            <ui:TextBlock FontTypography="Subtitle" HorizontalAlignment="Center"
                                          Text="{Binding TotalMonthlyEmi, StringFormat='&#x20B9;{0:N0}'}" />
                        </StackPanel>
                    </ui:Card>
                    <ui:Card Grid.Column="4" Padding="12">
                        <StackPanel VerticalAlignment="Center">
                            <ui:TextBlock Appearance="Secondary" FontTypography="Caption"
                                          HorizontalAlignment="Center" Text="Interest Payable" Margin="0,0,0,6" />
                            <ui:TextBlock FontTypography="Subtitle" HorizontalAlignment="Center"
                                          Text="{Binding TotalInterestPayable, StringFormat='&#x20B9;{0:N0}'}" />
                        </StackPanel>
                    </ui:Card>
                    <ui:Card Grid.Column="6" Padding="12">
                        <StackPanel VerticalAlignment="Center">
                            <ui:TextBlock Appearance="Secondary" FontTypography="Caption"
                                          HorizontalAlignment="Center" Text="Active Loans" Margin="0,0,0,6" />
                            <ui:TextBlock FontTypography="Subtitle" HorizontalAlignment="Center"
                                          Text="{Binding ActiveLoanCount}" />
                        </StackPanel>
                    </ui:Card>
                </Grid>

                <!-- Summary cards row 2 -->
                <Grid Margin="0,0,0,16" Height="100">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <ui:Card Grid.Column="0" Padding="12">
                        <StackPanel VerticalAlignment="Center">
                            <ui:TextBlock Appearance="Secondary" FontTypography="Caption"
                                          HorizontalAlignment="Center" Text="Debt-to-Income" Margin="0,0,0,6" />
                            <ui:TextBlock FontTypography="Subtitle" HorizontalAlignment="Center"
                                          Text="{Binding DebtToIncomePercent, StringFormat='{}{0:0.#}%'}" />
                        </StackPanel>
                    </ui:Card>
                    <ui:Card Grid.Column="2" Padding="12">
                        <StackPanel VerticalAlignment="Center">
                            <ui:TextBlock Appearance="Secondary" FontTypography="Caption"
                                          HorizontalAlignment="Center" Text="Loan Health Score" Margin="0,0,0,6" />
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <ui:TextBlock FontTypography="Subtitle"
                                              Text="{Binding LoanHealthScore}" Margin="0,0,6,0" />
                                <ui:TextBlock FontTypography="Caption" Appearance="Secondary"
                                              Text="{Binding LoanHealthRating}" VerticalAlignment="Bottom"
                                              Margin="0,0,0,2" />
                            </StackPanel>
                        </StackPanel>
                    </ui:Card>
                    <ui:Card Grid.Column="4" Padding="12">
                        <StackPanel VerticalAlignment="Center">
                            <ui:TextBlock Appearance="Secondary" FontTypography="Caption"
                                          HorizontalAlignment="Center" Text="Net Worth"
                                          Margin="0,0,0,6" TextWrapping="Wrap" />
                            <ui:TextBlock FontTypography="Subtitle" HorizontalAlignment="Center"
                                          Text="{Binding NetWorth, StringFormat='&#x20B9;{0:N0}'}" />
                        </StackPanel>
                    </ui:Card>
                </Grid>

                <!-- Debt health -->
                <ui:TextBlock FontTypography="BodyStrong" Text="Debt Health Analysis" Margin="0,0,0,8" />
                <ItemsControl ItemsSource="{Binding DebtHealthRows}" Margin="0,0,0,8">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180" />
                                    <ColumnDefinition Width="80" />
                                    <ColumnDefinition Width="90" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <ui:TextBlock Grid.Column="0" Text="{Binding Label}" />
                                <ui:TextBlock Grid.Column="1"
                                              Text="{Binding ValuePercent, StringFormat='{}{0:0.#}%'}" />
                                <ui:TextBlock Grid.Column="2" Text="{Binding Band}"
                                              FontTypography="Caption" />
                                <ui:TextBlock Grid.Column="3" Text="{Binding Hint}"
                                              Appearance="Secondary" FontTypography="Caption"
                                              TextWrapping="Wrap" />
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <ItemsControl ItemsSource="{Binding Recommendations}" Margin="0,0,0,16">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <ui:TextBlock Text="{Binding}" TextWrapping="Wrap"
                                          Margin="0,0,0,4" Appearance="Secondary" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Loan list -->
                <ui:TextBlock FontTypography="BodyStrong" Text="Your loans" Margin="0,0,0,8" />
                <DataGrid ItemsSource="{Binding Items}" AutoGenerateColumns="False"
                          MinHeight="220" IsReadOnly="True" CanUserAddRows="False"
                          HeadersVisibility="Column" GridLinesVisibility="Horizontal">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Type" Binding="{Binding TypeName}" Width="Auto" />
                        <DataGridTextColumn Header="Borrower" Binding="{Binding BorrowerName}" Width="*" />
                        <DataGridTextColumn Header="Provider" Binding="{Binding Provider}" Width="*" />
                        <DataGridTextColumn Header="Outstanding"
                                            Binding="{Binding OutstandingAmount, StringFormat='&#x20B9;{0:N0}'}"
                                            Width="Auto" />
                        <DataGridTextColumn Header="EMI"
                                            Binding="{Binding EmiAmount, StringFormat='&#x20B9;{0:N0}'}"
                                            Width="Auto" />
                        <DataGridTextColumn Header="Rate"
                                            Binding="{Binding InterestRate, StringFormat='{}{0:0.##}%'}"
                                            Width="Auto" />
                        <DataGridTextColumn Header="Next due"
                                            Binding="{Binding NextDueDate, StringFormat=d}"
                                            Width="Auto" />
                        <DataGridTextColumn Header="Status" Binding="{Binding StatusName}" Width="Auto" />
                        <DataGridTemplateColumn Header="Actions" Width="Auto">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <ui:Button Content="Edit" Padding="8,2" Margin="0,0,4,0"
                                                   Tag="{Binding Id}" Click="OnEditLoan" />
                                        <ui:Button Content="Details" Padding="8,2" Margin="0,0,4,0"
                                                   Tag="{Binding Id}" Click="OnViewDetails" />
                                        <ui:Button Content="Delete" Padding="8,2"
                                                   Tag="{Binding Id}" Click="OnDeleteLoan" />
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <ui:TextBlock Margin="0,16,0,0" Appearance="Secondary" TextWrapping="Wrap"
                              Text="No loans yet. Add a home, education, vehicle or other loan to track EMIs, prepayments and debt health."
                              Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisibilityConverter}}" />

            </StackPanel>
        </ScrollViewer>
    </Grid>
</ui:FluentWindow>