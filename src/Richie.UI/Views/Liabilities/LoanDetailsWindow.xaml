<ui:FluentWindow x:Class="Richie.UI.Views.Liabilities.LoanDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        Title="Loan details"
        Height="700" Width="560"
        WindowStartupLocation="CenterOwner"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        WindowCornerPreference="Round">
    <ui:FluentWindow.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </ui:FluentWindow.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="{Binding LoanTitle}" />

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24,8,24,16">
            <StackPanel>
                <ui:TextBlock FontTypography="TitleLarge" Text="{Binding LoanTitle}" Margin="0,0,0,4" />
                <ui:TextBlock Appearance="Secondary" Text="{Binding StatusName}" Margin="0,0,0,12" />

                <Grid Margin="0,0,0,16" Height="90">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <ui:Card Grid.Column="0" Padding="10">
                        <StackPanel VerticalAlignment="Center">
                            <ui:TextBlock Appearance="Secondary" FontTypography="Caption"
                                          HorizontalAlignment="Center" Text="Outstanding" />
                            <ui:TextBlock FontTypography="Subtitle" HorizontalAlignment="Center"
                                          Text="{Binding OutstandingAmount, StringFormat='₹{0:N0}'}" />
                        </StackPanel>
                    </ui:Card>
                    <ui:Card Grid.Column="2" Padding="10">
                        <StackPanel VerticalAlignment="Center">
                            <ui:TextBlock Appearance="Secondary" FontTypography="Caption"
                                          HorizontalAlignment="Center" Text="EMI" />
                            <ui:TextBlock FontTypography="Subtitle" HorizontalAlignment="Center"
                                          Text="{Binding EmiAmount, StringFormat='₹{0:N0}'}" />
                        </StackPanel>
                    </ui:Card>
                    <ui:Card Grid.Column="4" Padding="10">
                        <StackPanel VerticalAlignment="Center">
                            <ui:TextBlock Appearance="Secondary" FontTypography="Caption"
                                          HorizontalAlignment="Center" Text="Remaining" />
                            <ui:TextBlock FontTypography="Subtitle" HorizontalAlignment="Center"
                                          Text="{Binding RemainingMonths, StringFormat='{}{0} mo'}" />
                        </StackPanel>
                    </ui:Card>
                </Grid>

                <ui:TextBlock FontTypography="BodyStrong" Text="Record a payment" Margin="0,0,0,8" />
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <ui:TextBox Grid.Column="0" PlaceholderText="Amount"
                                Text="{Binding PaymentAmount, UpdateSourceTrigger=PropertyChanged}" />
                    <DatePicker Grid.Column="2" SelectedDate="{Binding PaymentDate}" />
                </Grid>
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <ui:TextBox Grid.Column="0" PlaceholderText="Principal component (EMI only)"
                                Text="{Binding PrincipalComponent, UpdateSourceTrigger=PropertyChanged}" />
                    <ui:TextBox Grid.Column="2" PlaceholderText="Interest component (EMI only)"
                                Text="{Binding InterestComponent, UpdateSourceTrigger=PropertyChanged}" />
                </Grid>
                <ui:TextBox PlaceholderText="Note (optional)" Margin="0,0,0,8"
                            Text="{Binding PaymentNote, UpdateSourceTrigger=PropertyChanged}" />
                <ui:TextBlock Foreground="#C42B1C" TextWrapping="Wrap"
                              Text="{Binding Error}" Margin="0,0,0,8" />
                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                    <ui:Button Content="Record EMI" Appearance="Primary" Margin="0,0,8,0"
                               Command="{Binding RecordEmiCommand}" />
                    <ui:Button Content="Record prepayment" Margin="0,0,8,0"
                               Command="{Binding RecordPrepaymentCommand}" />
                    <ui:Button Content="Close loan" Command="{Binding CloseLoanCommand}" />
                </StackPanel>

                <ui:TextBlock FontTypography="BodyStrong" Text="Payment history" Margin="0,0,0,8" />
                <DataGrid ItemsSource="{Binding Payments}" AutoGenerateColumns="False"
                          MinHeight="180" IsReadOnly="True" CanUserAddRows="False"
                          HeadersVisibility="Column" GridLinesVisibility="Horizontal">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Type" Binding="{Binding PaymentType}" Width="Auto" />
                        <DataGridTextColumn Header="Amount"
                                            Binding="{Binding Amount, StringFormat='₹{0:N0}'}" Width="Auto" />
                        <DataGridTextColumn Header="Date"
                                            Binding="{Binding PaymentDate, StringFormat=d}" Width="Auto" />
                        <DataGridTextColumn Header="Note" Binding="{Binding Note}" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>

                <ui:TextBlock Margin="0,12,0,0" Appearance="Secondary" Text="No payments recorded yet."
                              Visibility="{Binding HasNoPayments, Converter={StaticResource BoolToVisibilityConverter}}" />
            </StackPanel>
        </ScrollViewer>
    </Grid>
</ui:FluentWindow>