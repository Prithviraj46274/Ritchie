<Window x:Class="Richie.UI.Views.FirstRunWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        mc:Ignorable="d"
        Title="Richie"
        Height="380" Width="520"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource ApplicationBackgroundBrush}">
    <Border BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="1">
        <StackPanel Margin="36" VerticalAlignment="Center">

            <Image Source="pack://application:,,,/Assets/richie-logo.png"
                   Width="80" Height="80" HorizontalAlignment="Center"
                   RenderOptions.BitmapScalingMode="HighQuality" />

            <ui:TextBlock FontTypography="TitleLarge" Text="Welcome to Richie"
                         HorizontalAlignment="Center" Margin="0,14,0,6" />

            <ui:TextBlock Appearance="Secondary" TextWrapping="Wrap" TextAlignment="Center"
                         Text="Richie will create an encrypted local workspace on this device. Your financial data never leaves this machine."
                         Margin="0,0,0,18" />

            <ui:TextBlock Appearance="Secondary" Text="Data will be stored at:" Margin="0,0,0,4" />
            <Border Background="{DynamicResource ControlFillColorDefaultBrush}"
                    CornerRadius="4" Padding="12,8" Margin="0,0,0,24">
                <TextBlock x:Name="DataPathText" FontFamily="Consolas" FontSize="12"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
            </Border>

            <ui:Button x:Name="SetupButton"
                       Content="Set up Richie"
                       Appearance="Primary"
                       HorizontalAlignment="Stretch"
                       Click="OnSetup" />

            <Button Content="Cancel"
                    Background="Transparent" BorderThickness="0"
                    Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                    HorizontalAlignment="Center"
                    Margin="0,10,0,0"
                    Cursor="Hand"
                    Click="OnCancel" />

        </StackPanel>
    </Border>
</Window>
