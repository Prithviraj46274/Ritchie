<Page x:Class="Richie.UI.Views.Pages.PasswordVaultPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      mc:Ignorable="d"
      Title="Password Vault"
      Loaded="OnLoaded">
    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </Page.Resources>
    <Grid Margin="24">

        <!-- Locked / setup gate -->
        <Grid Visibility="{Binding IsLocked, Converter={StaticResource BoolToVisibilityConverter}}">
            <ui:Card MaxWidth="420" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="24">
                <StackPanel>
                    <ui:SymbolIcon Symbol="LockClosed24" FontSize="32" HorizontalAlignment="Center" />
                    <ui:TextBlock FontTypography="TitleLarge" TextAlignment="Center" Margin="0,12,0,4"
                                  Text="{Binding GateHeading}" />
                    <ui:TextBlock Appearance="Secondary" TextAlignment="Center" TextWrapping="Wrap"
                                  Margin="0,0,0,16" Text="{Binding GateDescription}" />
                    <ui:PasswordBox x:Name="MasterPasswordBox" PlaceholderText="Master password"
                                    Password="{Binding MasterPassword, UpdateSourceTrigger=PropertyChanged}"
                                    KeyDown="OnMasterPasswordKeyDown" />
                    <ui:TextBlock Foreground="#C42B1C" TextWrapping="Wrap" Margin="0,8,0,0"
                                  Text="{Binding Error}" />
                    <ui:Button Content="{Binding SubmitText}" Appearance="Primary" Margin="0,16,0,0"
                               HorizontalAlignment="Stretch" Click="OnSubmit" />
                </StackPanel>
            </ui:Card>
        </Grid>

        <!-- Unlocked vault -->
        <Grid Visibility="{Binding IsUnlocked, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,16">
                <ui:TextBlock FontTypography="TitleLarge" Text="Password Vault" VerticalAlignment="Center" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <ui:Button Content="Lock" Margin="0,0,8,0" Click="OnLock" />
                    <ui:Button Content="Add password" Appearance="Primary" Click="OnAddEntry" />
                </StackPanel>
            </Grid>

            <DataGrid Grid.Row="1" ItemsSource="{Binding Items}" AutoGenerateColumns="False"
                      IsReadOnly="True" CanUserAddRows="False" HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Account" Binding="{Binding AccountName}" Width="*" />
                    <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="Auto" />
                    <DataGridTextColumn Header="User ID" Binding="{Binding LoginId}" Width="*" />
                    <DataGridTemplateColumn Header="Password" Width="Auto">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="••••••••" VerticalAlignment="Center" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="Actions" Width="Auto">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <ui:Button Content="Edit" Padding="8,2" Margin="0,0,4,0"
                                               Tag="{Binding Id}" Click="OnEditEntry" />
                                    <ui:Button Content="Delete" Padding="8,2"
                                               Tag="{Binding Id}" Click="OnDeleteEntry" />
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</Page>
